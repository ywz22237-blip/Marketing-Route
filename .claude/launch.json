{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "OSMU Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8002", "--reload", "--reload-dir", "backend"],
      "port": 8002
    },
    {
      "name": "OSMU Frontend (Static HTML)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000", "--directory", "frontend"],
      "port": 3000
    }
  ]
}
