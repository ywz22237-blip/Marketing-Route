# ============================
# OSMU SNS 자동화 플랫폼 환경변수
# ============================
# 이 파일을 복사해서 .env 로 저장 후 각 값을 채워주세요.
# cp .env.example .env

# --- [1] LLM (텍스트 가공) ---
GEMINI_API_KEY=your_gemini_api_key_here        # aistudio.google.com
GROQ_API_KEY=your_groq_api_key_here            # console.groq.com

# --- [2] 음성 (TTS / STT) ---
GOOGLE_TTS_API_KEY=your_google_cloud_api_key   # console.cloud.google.com
# STT는 Groq Whisper 사용 (GROQ_API_KEY 공유)

# --- [3] 이미지 / 썸네일 생성 ---
HF_API_TOKEN=your_huggingface_token_here       # huggingface.co/settings/tokens
# Pollinations.ai는 API key 불필요 (URL 기반 무료)

# --- [4] 트렌드 / 크롤링 ---
SERP_API_KEY=your_serpapi_key_here             # serpapi.com (무료 100회/월)
DATA_GO_KR_KEY=your_data_go_kr_key_here        # data.go.kr

# --- [5] 자동화 (Make.com 웹훅) ---
MAKE_WEBHOOK_LINKEDIN=https://hook.eu1.make.com/your_linkedin_webhook
MAKE_WEBHOOK_INSTAGRAM=https://hook.eu1.make.com/your_instagram_webhook
MAKE_WEBHOOK_YOUTUBE=https://hook.eu1.make.com/your_youtube_webhook
MAKE_WEBHOOK_BLOG=https://hook.eu1.make.com/your_blog_webhook

# --- [6] 서버 설정 ---
APP_ENV=development
OUTPUT_DIR=./outputs
